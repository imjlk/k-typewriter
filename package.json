{
	"name": "sbs-typing-effect-block",
	"version": "1.0.0",
	"description": "A polished WordPress block for multilingual typewriter headlines and hero copy.",
	"author": "imjlk",
	"license": "GPL-2.0-or-later",
	"main": "build/index.js",
	"scripts": {
		"build": "wp-scripts build --experimental-modules",
		"env:clean": "wp-env clean all",
		"env:start": "wp-env start",
		"env:stop": "wp-env stop",
		"format": "wp-scripts format",
		"lint:css": "wp-scripts lint-style",
		"lint:js": "wp-scripts lint-js",
		"make:pot": "wp-env run cli --env-cwd=wp-content/plugins/k-typewriter wp i18n make-pot . languages/sbs-typing-effect-block.pot --slug=sbs-typing-effect-block --domain=sbs-typing-effect-block --exclude=node_modules,.git,coverage,test-results,playwright-report --allow-root",
		"packages-update": "wp-scripts packages-update",
		"plugin-zip:upstream": "wp-scripts plugin-zip",
		"plugin-zip": "node ./scripts/build-release-zip.mjs",
		"start": "wp-scripts start --experimental-modules",
		"test:smoke": "playwright test",
		"test:unit": "wp-scripts test-unit-js --runInBand"
	},
	"engines": {
		"node": ">=20.0.0"
	},
	"devDependencies": {
		"@beavercoding/uni-typer": "1.0.1",
		"@playwright/test": "^1.58.2",
		"@types/react": "^18.3.3",
		"@types/wordpress__block-editor": "^11.5.15",
		"@wordpress/env": "^11.2.0",
		"@wordpress/interactivity": "^6.42.0",
		"@wordpress/scripts": "^31.7.0",
		"react": "^18.3.1",
		"react-dom": "^18.3.1",
		"typescript": "^5.4.5"
	}
}
