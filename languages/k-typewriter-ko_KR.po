#. Plugin Name of the plugin
#: k-typewriter.php
msgid "K Typewriter"
msgstr "K Typewriter"

#. Plugin URI of the plugin
#: k-typewriter.php
msgid "https://github.com/imjlk/k-typewriter"
msgstr "https://github.com/imjlk/k-typewriter"

#. Description of the plugin
#: k-typewriter.php
msgid ""
"Add a configurable typewriter text block for hero headlines, notices, and "
"multilingual messaging."
msgstr ""
"히어로 헤드라인, 공지, 다국어 메시지에 사용할 수 있는 설정형 타이프라이터 텍"
"스트 블록을 추가합니다."

#. Author of the plugin
#: k-typewriter.php
msgid "imjlk"
msgstr "imjlk"

#. Author URI of the plugin
#: k-typewriter.php
msgid "https://github.com/imjlk"
msgstr "https://github.com/imjlk"

#: includes/class-k-typewriter-plugin.php:176 build/index.js:1
msgid "한 글자씩, 리듬 있게."
msgstr "한 글자씩, 리듬 있게."

#: includes/class-k-typewriter-plugin.php:177 build/index.js:1
msgid "Animate headlines in any language."
msgstr "어떤 언어든 자연스럽게 헤드라인을 애니메이션하세요."

#: includes/class-k-typewriter-plugin.php:178 build/index.js:1
msgid "Ship polished hero copy in minutes."
msgstr "완성도 높은 히어로 카피를 몇 분 만에 배포하세요."

#. translators: %s: locale-aware list of animated messages.
#: includes/class-k-typewriter-plugin.php:215
msgid "Typewriter animation that sequentially types %s."
msgstr "%s가 순차적으로 타이핑되는 애니메이션"

#: build/index.js:1
msgid "First start only"
msgstr "처음 시작할 때만"

#: build/index.js:1
msgid "Every cycle"
msgstr "매 사이클마다"

#: build/index.js:1
msgid "Every re-entry"
msgstr "다시 진입할 때마다"

#: build/index.js:1
msgid "Backspace previous message"
msgstr "이전 메시지를 백스페이스"

#: build/index.js:1
msgid "Restart from empty"
msgstr "빈 상태에서 다시 시작"

#: build/index.js:1
msgid "Top"
msgstr "위쪽"

#: build/index.js:1
msgid "Middle"
msgstr "가운데"

#: build/index.js:1
msgid "Bottom"
msgstr "아래쪽"

#: build/index.js:1
msgid "Auto"
msgstr "자동"

#: build/index.js:1
msgid "Left to right"
msgstr "왼쪽에서 오른쪽"

#: build/index.js:1
msgid "Right to left"
msgstr "오른쪽에서 왼쪽"

#: build/index.js:1
msgid "Characters (ch)"
msgstr "문자 수(ch)"

#: build/index.js:1
msgid "Measure longest message"
msgstr "가장 긴 메시지 실측"

#: build/index.js:1
msgid "Blink"
msgstr "깜빡임"

#: build/index.js:1
msgid "Fade transition"
msgstr "페이드 전환"

#: build/index.js:1
msgid "Auto-generated"
msgstr "자동 생성"

#: build/index.js:1
msgid "Custom override"
msgstr "사용자 지정 덮어쓰기"

#: build/index.js:1
msgid "Auto uses the first message."
msgstr "자동 모드는 첫 번째 메시지를 사용합니다."

#: build/index.js:1
msgid "Custom mode lets you keep a different first-paint message."
msgstr "사용자 지정 모드에서는 처음 표시할 메시지를 별도로 유지할 수 있습니다."

#: build/index.js:1
msgid "Auto combines every message into a single summary."
msgstr "자동 모드는 모든 메시지를 하나의 요약으로 합칩니다."

#: build/index.js:1
msgid "Custom mode lets you write a shorter or more intentional summary."
msgstr ""
"사용자 지정 모드에서는 더 짧거나 의도적인 요약을 직접 작성할 수 있습니다."

#: build/index.js:1
msgid "Pause preview"
msgstr "미리보기 일시정지"

#: build/index.js:1
msgid "Play preview"
msgstr "미리보기 재생"

#: build/index.js:1
msgid "Content"
msgstr "콘텐츠"

#: build/index.js:1
msgid "Write one message per line. Empty lines are ignored."
msgstr "메시지를 한 줄에 하나씩 입력하세요. 빈 줄은 무시됩니다."

#: build/index.js:1
msgid "Messages"
msgstr "메시지"

#: build/index.js:1
msgid ""
"Auto follows the current site or page direction. Choose LTR or RTL only when "
"you want to override it."
msgstr ""
"자동은 현재 사이트 또는 페이지의 방향을 따릅니다. 필요할 때만 LTR 또는 RTL로 "
"덮어쓰세요."

#: build/index.js:1
msgid "Text direction"
msgstr "텍스트 방향"

#: build/index.js:1
msgid ""
"Shrink the block to its content so it fits more naturally inside groups and "
"flex layouts."
msgstr ""
"블록을 콘텐츠 크기에 맞게 줄여 그룹과 flex 레이아웃 안에서 더 자연스럽게 배치"
"합니다."

#: build/index.js:1
msgid "Inline layout"
msgstr "인라인 레이아웃"

#: build/index.js:1
msgid ""
"Auto lets the block grow naturally. Characters uses an approximate ch width. "
"Measure longest message uses the current font to reserve a steadier inline "
"width."
msgstr ""
"자동은 블록이 자연스럽게 늘어나고 줄어들게 둡니다. 문자 수(ch)는 대략적인 ch "
"폭을 사용합니다. 가장 긴 메시지 실측은 현재 폰트를 기준으로 더 안정적인 인라"
"인 폭을 예약합니다."

#: build/index.js:1
msgid "Inline width reserve"
msgstr "인라인 너비 예약"

#: build/index.js:1
msgid "Reserve width using an approximate number of character columns."
msgstr "대략적인 문자 칸 수를 기준으로 너비를 예약합니다."

#: build/index.js:1
msgid "Width in ch"
msgstr "ch 기준 너비"

#: build/index.js:1
msgid ""
"Choose a semantic text tag. Use H1 only when this block is the main page "
"heading."
msgstr ""
"의미에 맞는 텍스트 태그를 선택하세요. H1은 이 블록이 페이지의 메인 제목일 때"
"만 사용하세요."

#: build/index.js:1
msgid "Markup tag"
msgstr "마크업 태그"

#: build/index.js:1
msgid ""
"Reserve extra line height to reduce layout shift when longer messages wrap."
msgstr ""
"더 긴 메시지가 줄바꿈될 때 레이아웃이 흔들리지 않도록 줄 높이를 미리 확보합니"
"다."

#: build/index.js:1
msgid "Reserve lines"
msgstr "예약 줄 수"

#: build/index.js:1
msgid "Choose how the animated line sits inside the reserved height."
msgstr "애니메이션 줄이 예약된 높이 안에서 어디에 위치할지 선택하세요."

#: build/index.js:1
msgid "Vertical align"
msgstr "세로 정렬"

#: build/index.js:1
msgid "Fallback & Summary"
msgstr "폴백 및 요약"

#: build/index.js:1
msgid "Visible fallback"
msgstr "표시용 폴백"

#: build/index.js:1
msgid ""
"Shown before animation starts, with reduced motion, and without JavaScript."
msgstr ""
"애니메이션 시작 전, 동작 축소 모드, JavaScript 미사용 환경에서 표시됩니다."

#: build/index.js:1
msgid "Visible fallback source"
msgstr "표시용 폴백 소스"

#: build/index.js:1
msgid "Leave this empty to fall back to the first message."
msgstr "비워두면 첫 번째 메시지를 폴백으로 사용합니다."

#: build/index.js:1
msgid "Fallback override"
msgstr "폴백 덮어쓰기"

#: build/index.js:1
msgid "Effective fallback preview:"
msgstr "실제 적용될 폴백 미리보기:"

#: build/index.js:1
msgid "Non-visual summary"
msgstr "비시각 요약"

#: build/index.js:1
msgid ""
"Used by assistive technology when you want a fuller summary of every message."
msgstr "모든 메시지를 더 충분하게 전달하고 싶을 때 보조 기술에 사용됩니다."

#: build/index.js:1
msgid "Summary source"
msgstr "요약 소스"

#: build/index.js:1
msgid "Leave this empty to auto-generate the summary from every message."
msgstr "비워두면 모든 메시지로부터 요약을 자동 생성합니다."

#: build/index.js:1
msgid "Summary override"
msgstr "요약 덮어쓰기"

#: build/index.js:1
msgid "Effective non-visual summary:"
msgstr "실제 적용될 비시각 요약:"

#: build/index.js:1
msgid "Animation"
msgstr "애니메이션"

#: build/index.js:1
msgid "Typing delay (ms)"
msgstr "타이핑 지연(ms)"

#: build/index.js:1
msgid ""
"Choose whether each new message backspaces the previous one or restarts from "
"an empty state."
msgstr ""
"각 메시지가 이전 메시지를 백스페이스할지, 빈 상태에서 다시 시작할지 선택하세"
"요."

#: build/index.js:1
msgid "Transition mode"
msgstr "전환 방식"

#: build/index.js:1
msgid "Deleting delay (ms)"
msgstr "삭제 지연(ms)"

#: build/index.js:1
msgid "Pause delay (ms)"
msgstr "일시정지 지연(ms)"

#: build/index.js:1
msgid "Choose when the extra delay should run before animation continues."
msgstr "애니메이션이 이어지기 전에 추가 지연을 언제 적용할지 선택하세요."

#: build/index.js:1
msgid "Start delay mode"
msgstr "시작 지연 방식"

#: build/index.js:1
msgid "Start delay (ms)"
msgstr "시작 지연(ms)"

#: build/index.js:1
msgid ""
"Clear the static fallback and type the first message from an empty state "
"when animation begins."
msgstr ""
"애니메이션이 시작될 때 정적인 폴백을 지우고 첫 메시지를 빈 상태에서부터 타이"
"핑합니다."

#: build/index.js:1
msgid "Type first message from empty"
msgstr "첫 메시지를 빈 상태에서 타이핑"

#: build/index.js:1
msgid ""
"Turn this off to stop on the final message instead of looping back to the "
"beginning."
msgstr "이 옵션을 끄면 처음으로 되돌아가지 않고 마지막 메시지에서 멈춥니다."

#: build/index.js:1
msgid "Loop messages"
msgstr "메시지 반복"

#: build/index.js:1
msgid "Start when visible"
msgstr "보일 때 시작"

#: build/index.js:1
msgid "Pause the animation while the pointer is over the block."
msgstr "포인터가 블록 위에 있는 동안 애니메이션을 일시정지합니다."

#: build/index.js:1
msgid "Pause on hover"
msgstr "호버 시 일시정지"

#: build/index.js:1
msgid "Cursor"
msgstr "커서"

#: build/index.js:1
msgid "Show cursor"
msgstr "커서 표시"

#: build/index.js:1
msgid ""
"Blink gives a crisp on-off cursor. Fade transition keeps the cursor softer "
"and more fluid."
msgstr ""
"깜빡임은 분명한 온오프 느낌의 커서를 만듭니다. 페이드 전환은 더 부드럽고 유연"
"한 움직임을 유지합니다."

#: build/index.js:1
msgid "Cursor animation"
msgstr "커서 애니메이션"

#: build/index.js:1
msgid "Adjust the cursor bar thickness relative to the current font size."
msgstr "현재 폰트 크기를 기준으로 커서 막대 두께를 조절합니다."

#: build/index.js:1
msgid "Cursor thickness"
msgstr "커서 두께"

#: build/index.js:1
msgid "Adjust the cursor bar height relative to the current font size."
msgstr "현재 폰트 크기를 기준으로 커서 막대 높이를 조절합니다."

#: build/index.js:1
msgid "Cursor height"
msgstr "커서 높이"

#: build/index.js:1
msgid "Adjust how quickly the cursor blinks."
msgstr "커서가 깜빡이는 속도를 조절합니다."

#: build/index.js:1
msgid "Cursor blink speed (ms)"
msgstr "커서 깜빡임 속도(ms)"

#: build/index.js:1
msgid "Adjust how quickly the cursor fades in and out."
msgstr "커서가 페이드 인과 페이드 아웃하는 속도를 조절합니다."

#: build/index.js:1
msgid "Cursor transition speed (ms)"
msgstr "커서 전환 속도(ms)"

#: build/index.js:1
msgid "Move the cursor slightly left or right to match your font better."
msgstr "폰트에 더 잘 맞도록 커서를 조금 왼쪽이나 오른쪽으로 조정합니다."

#: build/index.js:1
msgid "Cursor horizontal offset"
msgstr "커서 가로 오프셋"

#: build/index.js:1
msgid "Move the cursor slightly up or down to match your font better."
msgstr "폰트에 더 잘 맞도록 커서를 조금 위나 아래로 조정합니다."

#: build/index.js:1
msgid "Cursor vertical offset"
msgstr "커서 세로 오프셋"

#: build/index.js:1
msgid "Hide cursor when complete"
msgstr "완료 시 커서 숨기기"

#: build/block.json src/block.json
msgctxt "block title"
msgid "K Typewriter"
msgstr "K Typewriter"

#: build/block.json src/block.json
msgctxt "block description"
msgid ""
"Animate multilingual headlines, notices, and hero copy with a polished "
"typewriter effect."
msgstr ""
"다국어 헤드라인, 공지, 히어로 카피를 완성도 높은 타이프라이터 효과로 애니메이"
"션합니다."

#: build/block.json src/block.json
msgctxt "block keyword"
msgid "typewriter"
msgstr "타이프라이터"

#: build/block.json src/block.json
msgctxt "block keyword"
msgid "headline"
msgstr "헤드라인"

#: build/block.json src/block.json
msgctxt "block keyword"
msgid "hero"
msgstr "히어로"

